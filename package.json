{
  "name": "hitesh-test",
  "version": "0.1.0",
  "description": "OSS CLI for E2E Networks MyAccount.",
  "homepage": "https://github.com/hitesh9320/e2ectl#readme",
  "bugs": {
    "url": "https://github.com/hitesh9320/e2ectl/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hitesh9320/e2ectl.git"
  },
  "type": "module",
  "bin": {
    "hitesh-test": "dist/app/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node ./scripts/clean.mjs dist .tmp && tsc -p tsconfig.build.json",
    "clean": "node ./scripts/clean.mjs",
    "coverage": "npm run coverage:unit && npm run coverage:integration",
    "coverage:integration": "npm run build && c8 --all --src src --exclude-after-remap --exclude \"tests/**\" --exclude \"dist/**\" --exclude \"scripts/**\" --reporter text --reporter html --reporter lcov --report-dir coverage/integration node ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "coverage:unit": "vitest run --coverage",
    "dev": "node --import tsx ./src/app/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src tests vitest.config.ts vitest.integration.config.ts vitest.manual.config.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:manual": "vitest run --config vitest.manual.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "cli",
    "e2e",
    "cloud",
    "myaccount"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3"
  }
}
